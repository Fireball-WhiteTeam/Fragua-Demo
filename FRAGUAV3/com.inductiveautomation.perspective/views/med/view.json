            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[default]PLC_PRG/Hora_H}, \"00\") + \":\" + numberFormat({[default]PLC_PRG/Hora_M}, \"00\") + \":\" + numberFormat({[default]PLC_PRG/Hora_S}, \"00\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#e0f0ff",
                "fontSize": "13px",
                "fontWeight": "500"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "TopBar"
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "backgroundColor": "#0a1a2a",
            "borderBottom": "1px solid #1e3a5f",
            "padding": "10px 20px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "lbl_cuarto"
            },
            "props": {
              "style": {
                "color": "#7aaac8",
                "fontSize": "12px"
              },
              "text": "Temperatura de cuarto"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "val_cuarto"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[default]PLC_PRG/Alta_Temp}, \"#0.00\") + \" °C\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#e0f0ff",
                "fontSize": "28px",
                "fontWeight": "500"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "lbl_iny"
            },
            "props": {
              "style": {
                "color": "#4fc3f7",
                "fontSize": "13px"
              },
              "text": "Inyeccion: -18.3 C"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "lbl_sp"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Setpoint cuarto \"+ numberFormat({[default]PLC_PRG/Alta_SP}, \"#0.00\") + \" °C\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#4fc3f7",
                "fontSize": "13px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "lbl_dsh"
            },
            "props": {
              "style": {
                "color": "#ffb74d",
