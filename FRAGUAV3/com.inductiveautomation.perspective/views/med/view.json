            "props": {
              "style": {
                "color": "#777777",
                "fontSize": "13px"
              },
              "text": "Deshielo: Inactivo"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "cool"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Cooling: \"+ if({[default]PLC_PRG/Alta_On},\"ON\",\"OFF\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#66bb6a",
                "fontSize": "13px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "lbl_ajustes"
            },
            "props": {
              "style": {
                "color": "#7aaac8",
                "fontSize": "12px",
                "marginTop": "16px"
              },
              "text": "Ajustar Setpoints"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "lbl"
                },
                "props": {
                  "style": {
                    "color": "#7aaac8",
                    "fontSize": "13px"
                  },
                  "text": "Setpoint cuarto"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "input_sp_cuarto"
                },
                "propConfig": {
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "fallbackDelay": 2.5,
                        "mode": "direct",
                        "tagPath": "[default]PLC_PRG/Alta_SP"
                      },
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "style": {
                    "backgroundColor": "#0a1520",
                    "borderColor": "#1e6a9e",
                    "color": "#e0f0ff",
                    "textAlign": "right",
                    "width": "90px"
                  }
                },
                "type": "ia.input.numeric-entry-field"
              }
            ],
            "meta": {
              "name": "row_sp_cuarto"
            },
            "props": {
              "alignItems": "center",
              "justify": "space-between",
              "style": {
                "padding": "4px 0"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "lbl"
                },
                "props": {
                  "style": {
                    "color": "#7aaac8",
                    "fontSize": "13px"
                  },
                  "text": "Setpoint deshielo"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "input_sp_deshielo"
