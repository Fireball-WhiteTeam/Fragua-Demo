            "gap": "4px",
            "margin": "12px",
            "padding": "20px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#081420",
        "gap": "0px",
        "height": "100%",
