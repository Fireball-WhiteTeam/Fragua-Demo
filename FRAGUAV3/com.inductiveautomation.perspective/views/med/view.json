                    "fontWeight": "500"
                  },
                  "text": "Camara Media Temp"
                },
                "type": "ia.display.label"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "dot"
                    },
                    "props": {
                      "style": {
                        "color": "#66bb6a",
                        "fontSize": "10px"
                      },
                      "text": "●"
                    },
                    "type": "ia.display.label"
                  },
                  {
                    "meta": {
                      "name": "lbl"
                    },
                    "props": {
                      "style": {
                        "color": "#66bb6a",
                        "fontSize": "11px",
                        "fontWeight": "500"
                      },
                      "text": "Modbus Online"
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "modbus_badge"
                },
                "props": {
                  "alignItems": "center",
                  "style": {
                    "backgroundColor": "#0a2a1a",
                    "border": "1px solid #1a6a3a",
                    "borderRadius": "12px",
                    "gap": "6px",
                    "padding": "2px 10px"
                  }
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "left"
