            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "comp"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Compresor: \"+ if({[default]PLC_PRG/Alta_On},\"ON\",\"OFF\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#66bb6a",
                "fontSize": "13px"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "fan"
            },
            "props": {
              "style": {
                "color": "#66bb6a",
                "fontSize": "13px"
              },
              "text": "Fan: ON"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "sol"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Compresor: \"+ if({[default]PLC_PRG/Alta_On},\"ON\",\"OFF\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#66bb6a",
                "fontSize": "13px"
              }
